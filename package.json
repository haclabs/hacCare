{
  "name": "haccare",
  "private": true,
  "version": "5.5.0",
  "type": "module",
  "description": "Advanced Healthcare Management System with BCMA barcode medication administration, diabetic care, security diagnostics, and comprehensive patient management",
  "keywords": [
    "healthcare",
    "patient-management",
    "bcma",
    "barcode-scanner",
    "medication-administration",
    "diabetic-care",
    "security-diagnostics",
    "medical",
    "react",
    "typescript"
  ],
  "author": "hacCare Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "./node_modules/.bin/vite build && node scripts/prerender.mjs",
    "build:fallback": "npx --package=typescript tsc && npx --package=vite vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "preview": "vite preview",
    "type-check": "./node_modules/.bin/tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:tenant-isolation": "vite-node test-tenant-isolation.ts",
    "supabase:types": "supabase gen types typescript --linked > src/types/supabase.ts",
    "clean": "rm -rf dist node_modules/.vite",
    "deps:update": "ncu -u && npm install",
    "deps:check": "ncu",
    "postinstall": "echo 'Dependencies installed successfully'"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.100.14",
    "@types/jsbarcode": "^3.11.4",
    "@types/jspdf": "^1.3.3",
    "date-fns": "^4.3.0",
    "dompurify": "^3.4.5",
    "html2canvas": "^1.4.1",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.1.0",
    "lucide-react": "^1.16.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.6",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-image-marker": "^1.2.0",
    "react-router-dom": "^7.15.1",
    "run": "^1.5.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.15",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "npm-check-updates": "^22.2.1",
    "postcss": "^8.5.15",
    "rollup-plugin-visualizer": "^7.0.1",
    "supabase": "^2.101.0",
    "tailwindcss": "^4.1.18",
    "terser": "^5.48.0",
    "ts-prune": "^0.10.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
